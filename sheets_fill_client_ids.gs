// ========= NORMALIZACIÓN =========
function normalizeName(s) {
  if (s == null) return '';
  return String(s)
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')   // strip combining marks (acentos)
    .replace(/\s+/g, ' ');              // colapsar espacios
}

// ========= ACCIÓN PRINCIPAL =========
function fillClientIds() {
  const ss = SpreadsheetApp.getActive();
  const sheet = SHEET_NAME ? ss.getSheetByName(SHEET_NAME) : ss.getActiveSheet();
  if (!sheet) throw new Error('Hoja no encontrada: ' + SHEET_NAME);

  const lastRow = sheet.getLastRow();
  if (lastRow < FIRST_DATA_ROW) {
    SpreadsheetApp.getUi().alert('No hay filas de datos.');
    return;
  }

  const numRows = lastRow - FIRST_DATA_ROW + 1;
  const namesRange = sheet.getRange(FIRST_DATA_ROW, CLIENT_NAME_COL, numRows, 1);
  const idsRange   = sheet.getRange(FIRST_DATA_ROW, CLIENT_ID_COL,   numRows, 1);

  const names = namesRange.getValues();
  const ids   = idsRange.getValues();

  let matched = 0;
  let missing = 0;
  let empty = 0;
  const missingSamples = [];

  for (let i = 0; i < names.length; i++) {
    const rawName = names[i][0];
    if (!rawName || String(rawName).trim() === '') {
      ids[i][0] = '';
      empty++;
      continue;
    }
    const key = normalizeName(rawName);
    const found = CLIENT_MAP[key];
    if (found) {
      ids[i][0] = found;
      matched++;
    } else {
      ids[i][0] = '';
      missing++;
      if (missingSamples.length < 20) missingSamples.push(rawName);
    }
  }

  idsRange.setValues(ids);

  const msg =
    'Coincidencias: ' + matched + '\n' +
    'Sin match:     ' + missing + '\n' +
    'Filas vacías:  ' + empty + '\n' +
    'Total filas:   ' + numRows +
    (missingSamples.length
       ? '\n\nEjemplos sin match (max 20):\n - ' + missingSamples.join('\n - ')
       : '');
  SpreadsheetApp.getUi().alert('Resultado del mapeo', msg, SpreadsheetApp.getUi().ButtonSet.OK);
}
